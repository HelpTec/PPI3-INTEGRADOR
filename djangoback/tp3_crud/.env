# .env
TWITCH_CLIENT_ID="ryibth8v88mg80rr07x098mvv3i696"
TWITCH_CLIENT_SECRET="0tt88o4ww4cf0htqfj8vnqi3fiv1d1"

# Configuración de Active Directory / LDAP
# Ejemplo para Windows Server 2008 AD:
# LDAP_AUTH_URL="ldap://192.168.1.10:389"
# Si usas SSL: LDAP_AUTH_URL="ldaps://192.168.1.10:636"
LDAP_AUTH_URL="ldap://tu-servidor-ad.dominio.local:389"

# Usuario con permisos de lectura en AD para hacer búsquedas (bind user)
# Formato: CN=nombre,CN=Users,DC=dominio,DC=local
LDAP_AUTH_CONNECTION_USERNAME="CN=bind_user,CN=Users,DC=dominio,DC=local"
LDAP_AUTH_CONNECTION_PASSWORD="password_del_bind_user"

# Base DN donde buscar usuarios (generalmente CN=Users,DC=dominio,DC=local)
LDAP_AUTH_SEARCH_BASE="CN=Users,DC=dominio,DC=local"